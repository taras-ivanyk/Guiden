# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
STRAVA_CLIENT_ID=12345

# ── OpenAI / LLM ──────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=                          # leave blank for default OpenAI endpoint
LLM_TEMPERATURE=0.4
MAX_OUTPUT_TOKENS=1500

# ── Token budget & cost tracking ──────────────────────────────────────────────
SESSION_TOKEN_BUDGET=50000               # LLM calls blocked above this limit
COST_PER_M_INPUT=0.15                    # USD per 1M input tokens (gpt-4o-mini)
COST_PER_M_OUTPUT=0.60                   # USD per 1M output tokens (gpt-4o-mini)

# ── Strava / activity fetching ────────────────────────────────────────────────
TOP_K_ACTIVITIES=10                      # default recent activities to load
DEFAULT_WEEKS_AHEAD=4                    # default training plan length in weeks

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING
